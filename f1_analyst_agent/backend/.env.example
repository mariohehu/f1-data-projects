# This agent runs on a LOCAL Ollama model by default — no API key, no cost.
# These are OPTIONAL overrides; the defaults work out of the box.

# Which Ollama model to use (must support tool calling, e.g. gemma4, llama3.1)
OLLAMA_MODEL=gemma4:latest

# Ollama server URL (default is the standard local port)
OLLAMA_BASE_URL=http://localhost:11434/v1
